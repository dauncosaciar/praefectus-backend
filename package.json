{
  "name": "address-dashboard-backend",
  "version": "1.0.0",
  "description": "Address Dashboard Backend",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --exec ts-node src/index.ts",
    "dev:api": "cross-env NODE_ENV=development nodemon --exec ts-node src/index.ts --api",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node ./dist/index.js",
    "test": "cross-env NODE_ENV=test jest --detectOpenHandles",
    "test:coverage": "cross-env NODE_ENV=test jest --detectOpenHandles --coverage"
  },
  "keywords": [
    "typescript",
    "express",
    "mongodb"
  ],
  "author": "Daniel Alejandro Uncos Aciar",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "colors": "^1.4.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
